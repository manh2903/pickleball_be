PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pickleball_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=pickleball_jwt_secret_key_2024_very_long_and_secure
JWT_REFRESH_SECRET=pickleball_refresh_secret_key_2024_very_long_and_secure
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Pickleball Courts <noreply@pickleball.vn>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
